<div class="min-h-screen bg-gray-100 flex items-center justify-center p-4">
  <% if @business %>
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl flex flex-col h-[600px] overflow-hidden">
      <%# Header %>
      <header class="flex-shrink-0 bg-gradient-to-r from-blue-600 to-blue-700 px-4 py-3 flex items-center gap-3">
        <span class="text-2xl" aria-hidden="true">💬</span>
        <div class="flex-1 min-w-0">
          <h1 class="text-white font-semibold text-lg truncate"><%= @business.name %></h1>
          <p class="text-blue-100 text-sm flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse" aria-hidden="true"></span>
            Online
          </p>
        </div>
      </header>

      <%# Messages area %>
      <div id="messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50">
        <div class="flex">
          <div class="max-w-[85%] rounded-2xl rounded-tl-sm px-4 py-2.5 bg-gray-200 text-gray-900">
            <p class="text-sm">Hi! How can I help you today?</p>
          </div>
        </div>
      </div>

      <%# Typing indicator (hidden by default) %>
      <div id="typing-indicator" class="hidden px-4 pb-2">
        <div class="flex gap-1 items-center">
          <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 0ms"></div>
          <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 150ms"></div>
          <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 300ms"></div>
        </div>
      </div>

      <%# Input area %>
      <div class="flex-shrink-0 p-4 bg-white border-t border-gray-200">
        <form id="chat-form" data-business-id="<%= @business.id %>" class="flex gap-2">
          <input
            type="text"
            name="message"
            id="message-input"
            placeholder="Type a message..."
            autocomplete="off"
            class="flex-1 rounded-xl border border-gray-300 px-4 py-2.5 text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          >
          <button
            type="submit"
            class="flex-shrink-0 rounded-xl bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Send
          </button>
        </form>
      </div>
    </div>
  <% else %>
    <div class="max-w-md bg-white rounded-2xl shadow-xl p-8 text-center">
      <p class="text-gray-600">No business configured. Run <code class="bg-gray-100 px-2 py-1 rounded text-sm">bin/rails db:seed</code> to create the Demo Store.</p>
    </div>
  <% end %>
</div>

<% if @business %>
  <script>
    const form = document.getElementById("chat-form");
    const input = document.getElementById("message-input");
    const messagesEl = document.getElementById("messages");
    const typingEl = document.getElementById("typing-indicator");

    function scrollToBottom() {
      messagesEl.scrollTo({ top: messagesEl.scrollHeight, behavior: "smooth" });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const message = input.value.trim();
      if (!message) return;

      const userBubble = document.createElement("div");
      userBubble.className = "flex justify-end";
      userBubble.innerHTML = '<div class="max-w-[85%] rounded-2xl rounded-tr-sm px-4 py-2.5 bg-blue-600 text-white"><p class="text-sm">' + escapeHtml(message) + '</p></div>';
      messagesEl.appendChild(userBubble);

      input.value = "";
      input.disabled = true;

      typingEl.classList.remove("hidden");
      scrollToBottom();

      try {
        const csrfToken = document.querySelector('meta[name="csrf-token"]');
        const res = await fetch("/chat", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken ? csrfToken.getAttribute("content") : "",
            "Accept": "application/json"
          },
          body: JSON.stringify({
            business_id: form.dataset.businessId,
            message: message
          })
        });

        typingEl.classList.add("hidden");

        const contentType = res.headers.get("Content-Type") || "";
        let data;
        if (contentType.includes("application/json")) {
          data = await res.json();
        } else {
          const text = await res.text();
          throw new Error(res.ok ? "Invalid response from server." : "Request failed. Please try again.");
        }

        if (!res.ok) {
          throw new Error(data.error || "Request failed. Please try again.");
        }

        const assistantBubble = document.createElement("div");
        assistantBubble.className = "flex";
        assistantBubble.innerHTML = '<div class="max-w-[85%] rounded-2xl rounded-tl-sm px-4 py-2.5 bg-gray-200 text-gray-900"><p class="text-sm">' + escapeHtml(data.reply || "No response.") + '</p></div>';
        messagesEl.appendChild(assistantBubble);
      } catch (err) {
        typingEl.classList.add("hidden");

        const errBubble = document.createElement("div");
        errBubble.className = "flex";
        errBubble.innerHTML = '<div class="max-w-[85%] rounded-2xl rounded-tl-sm px-4 py-2.5 bg-red-100 text-red-800"><p class="text-sm">' + escapeHtml(err.message) + '</p></div>';
        messagesEl.appendChild(errBubble);
      }

      input.disabled = false;
      scrollToBottom();
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    function escapeHtml(text) {
      const div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
<% end %>
